<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <size
                android:width="14dp"
                android:height="14dp" />
            <stroke
                android:width="1.5dp"
                android:color="#FF6B6B" />
            <solid android:color="#2AC23A3A" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:width="9dp"
        android:height="1.6dp"
        android:rotation="45">
        <shape android:shape="rectangle">
            <solid android:color="#E8E3D9" />
            <corners android:radius="1dp" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:width="9dp"
        android:height="1.6dp"
        android:rotation="-45">
        <shape android:shape="rectangle">
            <solid android:color="#E8E3D9" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
